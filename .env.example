TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=Link2ActionBot
TELEGRAM_MAX_UPLOAD_FILE_SIZE_BYTES=20971520
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_FILE_DOWNLOAD_BASE_URL=https://api.telegram.org/file
TELEGRAM_FILE_DOWNLOAD_TIMEOUT_SECONDS=60

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/link2action
SPRING_DATASOURCE_USERNAME=link2action
SPRING_DATASOURCE_PASSWORD=link2action

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=linkscribe.exchange
RABBITMQ_REQUEST_QUEUE=linkscribe.transcription.requests
RABBITMQ_REQUEST_RETRY_QUEUE=linkscribe.transcription.requests.retry
RABBITMQ_REQUEST_DLQ=linkscribe.transcription.requests.dlq
RABBITMQ_RESULT_QUEUE=linkscribe.transcription.results
RABBITMQ_REQUEST_ROUTING_KEY=transcription.requested
RABBITMQ_RETRY_ROUTING_KEY=transcription.requested.retry
RABBITMQ_DLQ_ROUTING_KEY=transcription.requested.dlq
RABBITMQ_COMPLETED_ROUTING_KEY=transcription.completed
RABBITMQ_FAILED_ROUTING_KEY=transcription.failed
RABBITMQ_PROGRESS_ROUTING_KEY=transcription.progress
RABBITMQ_RETRY_DELAY_MS=30000
RABBITMQ_MAX_RETRY_ATTEMPTS=3

RESULTS_BASE_PATH=/data/results
DOWNLOADS_BASE_PATH=/data/downloads

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=

MAX_VIDEO_DURATION_SECONDS=3600
MAX_ACTIVE_TASKS_PER_USER=1
MAX_BATCH_SIZE=5
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_CONNECTION_ATTEMPTS=30
RABBITMQ_CONNECTION_RETRY_SECONDS=2
WORKER_METRICS_ENABLED=true
WORKER_METRICS_PORT=9091
